document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
document.querySelector('[data-page="mapa"]').classList.add('active');
document.getElementById('page-mapa').classList.add('active');
document.querySelectorAll('.template-card').forEach(c=>c.classList.remove('active'));sP(1);}

function expC(){const nm=document.getElementById('cN').value||'Mi proceso';
let o='ENEAGRAMA: '+nm+'\n'+'═'.repeat(40)+'\n\n';
o+='SECCIÓN 1:\n  1. '+(document.getElementById('cp1').value||'—')+'\n  2. '+(document.getElementById('cp2').value||'—')+'\n\n';
o+='⚡ CHOQUE 1:\n  3. '+(document.getElementById('cp3').value||'—')+'\n\n';
o+='SECCIÓN 2:\n  4. '+(document.getElementById('cp4').value||'—')+'\n  5. '+(document.getElementById('cp5').value||'—')+'\n\n';
o+='⚡ CHOQUE 2:\n  6. '+(document.getElementById('cp6').value||'—')+'\n\n';
o+='SECCIÓN 3:\n  7. '+(document.getElementById('cp7').value||'—')+'\n  8. '+(document.getElementById('cp8').value||'—')+'\n\n';
o+='NUEVO CICLO:\n  9. '+(document.getElementById('cp9').value||'—')+'\n';
document.getElementById('cOC').style.display='block';document.getElementById('cO').textContent=o;
navigator.clipboard?.writeText(o).then(()=>{const t=document.getElementById('cT');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);});}
</script>
