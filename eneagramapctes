<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MenteIntegra - Eneagrama: Mapa de Procesos</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg-dark:#0a0a0f;--bg-card:#12121a;--bg-input:#1a1a25;--accent:#00d4aa;--accent-dim:#00a885;--warning:#ff9500;--danger:#ff3b3b;--purple:#b266ff;--blue:#4a9eff;--cyan:#5ce0d8;--text:#e8e8e8;--text-dim:#888;--border:#2a2a35;--section1:#ff6b4a;--section2:#ffb833;--section3:#00d4aa;--shock:#b266ff}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg-dark);color:var(--text);min-height:100vh;font-size:16px;line-height:1.6}
.nav{background:var(--bg-card);border-bottom:1px solid var(--border);padding:0 20px;position:sticky;top:0;z-index:100}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:20px}
.logo{font-size:1.3em;font-weight:700;color:var(--accent);padding:14px 0;white-space:nowrap}
.nav-tabs{display:flex;gap:3px;overflow-x:auto}
.nav-tab{padding:14px 16px;background:none;border:none;color:var(--text-dim);font-size:.9em;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.nav-tab:hover{color:var(--text)}.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.main{max-width:1200px;margin:0 auto;padding:20px}
.page{display:none}.page.active{display:block}
.card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:22px;margin-bottom:20px}
.card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;padding-bottom:15px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:10px}
.card-title{font-size:1.15em;font-weight:600;color:var(--accent)}
.template-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:18px}
.template-card{background:var(--bg-input);border:1px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;transition:all .2s}
.template-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.template-card.active{border-color:var(--accent);background:rgba(0,212,170,.06)}
.template-card h4{color:var(--accent);margin-bottom:4px;font-size:.95em}
.template-card p{color:var(--text-dim);font-size:.8em;line-height:1.4}
.legend{display:flex;flex-wrap:wrap;gap:14px;padding:12px 14px;background:var(--bg-input);border-radius:8px;font-size:.82em;margin-bottom:14px}
.legend-item{display:flex;align-items:center;gap:6px}
.legend-dot{width:12px;height:12px;border-radius:50%}
.walk-controls{display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--bg-input);border-radius:8px;margin-bottom:14px;flex-wrap:wrap}
.walk-controls .step-label{font-family:'Courier New',monospace;color:var(--accent);font-size:.9em}
.btn{padding:9px 18px;border:none;border-radius:8px;font-size:.92em;font-weight:600;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--accent);color:#000}.btn-primary:hover{background:var(--accent-dim)}
.btn-secondary{background:var(--bg-input);color:var(--text);border:1px solid var(--border)}.btn-secondary:hover{border-color:var(--accent)}
.enneagram-container{display:flex;gap:20px;align-items:flex-start}
.enneagram-svg-wrap{flex:1.1;min-width:0;max-width:520px}
.enneagram-info{flex:1;min-width:280px}
svg.enneagram{width:100%;height:auto}
.enn-circle{fill:none;stroke:var(--border);stroke-width:1.5}
.enn-progress-arc{fill:none;stroke:var(--warning);stroke-width:4;stroke-linecap:round;opacity:.7;transition:stroke-dashoffset .6s ease}
.enn-triangle-line{stroke:var(--shock);stroke-width:1.5;stroke-dasharray:8 4;opacity:.4}
.enn-hex-line{stroke:var(--text-dim);stroke-width:1;opacity:.2;transition:all .3s}
.enn-hex-line.highlight{opacity:.65;stroke:var(--accent);stroke-width:1.5}
.enn-point{cursor:pointer;transition:all .3s}
.enn-point circle{transition:all .3s}
.enn-point:hover circle{filter:brightness(1.3)}
.enn-point.active circle{filter:brightness(1.4);stroke:#fff;stroke-width:2.5}
.enn-point text{fill:#fff;font-size:14px;font-weight:700;text-anchor:middle;dominant-baseline:central;pointer-events:none}
.enn-label{font-size:9.5px;fill:var(--text-dim);text-anchor:middle;pointer-events:none;transition:fill .3s}
.enn-label.active{fill:#fff;font-weight:600;font-size:10px}
.point-info{background:var(--bg-input);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:14px;min-height:160px;transition:all .3s}
.point-info.shock{border-left:3px solid var(--shock)}
.point-info .point-number{font-size:2.2em;font-weight:700;font-family:'Courier New',monospace;line-height:1;margin-bottom:4px}
.point-info .point-section-label{font-size:.72em;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;display:inline-block;padding:2px 8px;border-radius:4px}
.point-info .point-title{font-size:1.1em;font-weight:600;margin-bottom:6px}
.point-info .point-desc{font-size:.92em;color:var(--text-dim);line-height:1.6}
.point-info .point-example{margin-top:10px;padding:10px 12px;background:rgba(0,212,170,.04);border-left:2px solid var(--accent);border-radius:0 6px 6px 0;font-size:.85em;line-height:1.5}
.point-info .octave-label{margin-top:8px;font-family:'Courier New',monospace;font-size:.82em;color:var(--purple)}
.octave-bar{display:flex;align-items:center;gap:0;padding:8px 10px;background:var(--bg-input);border-radius:10px;overflow-x:auto;margin-top:12px}
.octave-note{flex:1;text-align:center;padding:8px 3px;font-family:'Courier New',monospace;font-size:.78em;color:var(--text-dim);min-width:36px;cursor:pointer;transition:all .3s;border-radius:5px}
.octave-note.active{color:#fff;font-weight:700}
.octave-note.s1.active{background:rgba(255,107,74,.2);color:var(--section1)}
.octave-note.s2.active{background:rgba(255,184,51,.2);color:var(--section2)}
.octave-note.s3.active{background:rgba(0,212,170,.2);color:var(--section3)}
.octave-note.sk.active{background:rgba(178,102,255,.2);color:var(--shock)}
.octave-gap{width:4px;height:28px;background:var(--danger);border-radius:2px;margin:0 2px;opacity:.6;position:relative}
.octave-gap::after{content:'⚡';position:absolute;top:-16px;left:-6px;font-size:.65em}
.octave-arrow{color:var(--border);font-size:.65em;padding:0 1px}
.connections-box{margin-top:12px;font-size:.82em;color:var(--text-dim)}
.connections-box span{font-family:'Courier New',monospace;color:var(--accent);font-size:.9em}
.guide-section{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden}
.guide-header{padding:16px 20px;background:var(--bg-input);cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.guide-header:hover{background:#1f1f2a}
.guide-header h3{font-size:1.05em;color:var(--accent)}
.guide-toggle{font-size:1.2em;color:var(--text-dim);transition:transform .3s}
.guide-section.open .guide-toggle{transform:rotate(180deg)}
.guide-body{padding:0;max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s}
.guide-section.open .guide-body{padding:22px;max-height:6000px}
.diagram{background:#0d0d12;color:#00ff88;font-family:'Courier New',monospace;padding:16px;border-radius:8px;font-size:.82em;overflow-x:auto;white-space:pre;line-height:1.5;margin-bottom:12px}
.diagram.amber{color:var(--warning)}.diagram.cyan{color:var(--cyan)}.diagram.purple{color:var(--purple)}
.guide-note{padding:12px 16px;background:rgba(92,224,216,.06);border-left:3px solid var(--cyan);border-radius:0 8px 8px 0;font-size:.92em;line-height:1.6;color:var(--text);margin:12px 0}
.guide-note.warning{background:rgba(255,149,0,.06);border-left-color:var(--warning)}
.guide-note.purple{background:rgba(178,102,255,.06);border-left-color:var(--purple)}
.crear-grid{display:flex;flex-direction:column;gap:8px}
.crear-row{display:flex;align-items:center;gap:10px}
.crear-label{min-width:36px;font-family:'Courier New',monospace;font-weight:700;font-size:1.1em;text-align:center}
.crear-section-divider{padding:8px 14px;font-size:.78em;text-transform:uppercase;letter-spacing:2px;font-weight:600;border-radius:6px;margin:6px 0 2px}
.form-input{padding:10px 12px;background:var(--bg-input);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:.92em;transition:border-color .2s;width:100%}
.form-input:focus{outline:none;border-color:var(--accent)}
.form-input.shock-input{border-color:rgba(178,102,255,.4)}.form-input.shock-input:focus{border-color:var(--shock)}
.output-area{background:var(--bg-input);border:1px solid var(--border);border-radius:8px;padding:20px;font-family:'Courier New',monospace;font-size:.88em;line-height:1.6;white-space:pre-wrap;max-height:500px;overflow-y:auto}
.btn-group{display:flex;gap:10px;flex-wrap:wrap}
.copy-toast{position:fixed;bottom:30px;right:30px;background:var(--accent);color:#000;padding:12px 24px;border-radius:8px;font-weight:600;transform:translateY(100px);opacity:0;transition:all .3s;z-index:200}
.copy-toast.show{transform:translateY(0);opacity:1}
.vector-canvas{width:100%;height:auto;margin:10px 0}
@media(max-width:800px){.enneagram-container{flex-direction:column}.enneagram-svg-wrap{max-width:100%}.enneagram-info{min-width:0}.nav-inner{gap:10px}.logo{font-size:1.1em}.nav-tab{padding:12px 10px;font-size:.82em}.template-grid{grid-template-columns:1fr 1fr}body{font-size:15px}}
@media(max-width:480px){.template-grid{grid-template-columns:1fr}.main{padding:12px}.card{padding:16px}.walk-controls{gap:8px}.btn{padding:8px 14px;font-size:.85em}}
</style>
</head>
