const T={infelicidad:{name:"El reto de la infelicidad",points:{1:{title:"Soy infeliz",desc:"Me percato de que me siento infeliz. Esta infelicidad crea un conflicto que me impulsa a la acción.",example:"Desde el punto 1 miro hacia el 7 y veo un aspecto de la meta.",octave:"DO — Inicio"},2:{title:"Percibo situaciones repetitivas",desc:"Reconozco los patrones mecánicos. Los mismos comportamientos que me hacen infeliz. Neurosis: patrón compulsivo que coloca la felicidad más allá del alcance.",example:"Ahora puedo ver más claro mi propósito (punto 8).",octave:"RE"},3:{title:"Algo nuevo entra en mi vida",desc:"⚡ CHOQUE 1 (MI→FA). Necesito un estímulo EXTERNO: maestro, libro, terapeuta, grupo. Sin este impulso, permaneceré atrapado.",example:"Aquí la vibración se DESVÍA si no intervengo conscientemente.",octave:"MI→FA — ¡Sin semitono!"},4:{title:"Confronto mis mecanismos de defensa",desc:"Enormes tensiones internas. Hábitos antiguos dan batalla. PELIGRO: el punto 4 se conecta HACIA ATRÁS con 1 y 2 — tiendo a mirar el pasado con gafas rosa.",example:"Puedo romper con la terapia, buscar distracción, convencerme de que estoy bien.",octave:"SOL"},5:{title:"Uso la energía del conflicto",desc:"La liberación NO llega todavía. Pero reconozco qué me mantiene satisfecho. Debo aceptar el SUFRIMIENTO CONSCIENTE.",example:"El sufrimiento consciente prolongado rompe la programación.",octave:"LA"},6:{title:"Me despierto",desc:"⚡ CHOQUE 2 (SI→DO'). Los múltiples egos se funden en uno. TRANSMUTATIO alquímica. Se necesita nuevamente algo externo.",example:"El Self aparece en el carruaje y dice: vamos hacia allá.",octave:"SI→DO' — ¡Sin semitono!"},7:{title:"Sirvo a mi meta",desc:"Enfoco toda mi energía. Puedo servir con voluntad orientada.",example:"Veo claramente el punto 1 (origen) y el punto 5 (uso del conflicto).",octave:"RE'"},8:{title:"Logro mi meta",desc:"Alcanzo mi propósito. Reconozco que mis automatismos eran el origen de mi infelicidad.",example:"Lo que parecía insoportable en el punto 4 era necesario.",octave:"MI'"},9:{title:"Amor / Conciencia superior",desc:"Libre de entrar en un NUEVO proceso con conciencia ampliada. Amor consciente. Fin y principio: nuevo DO en octava superior.",example:"El punto 9 es simultáneamente fin y principio.",octave:"DO nueva octava"}}},cuerpoAlmaEspiritu:{name:"Cuerpo–Alma–Espíritu",points:{1:{title:"Mi cuerpo es flexible",desc:"Requisito previo para reconocer sentimientos (4) y comprenderme (7)."},2:{title:"Mantengo mi cuerpo sano",desc:"Esfuerzos para conservarme sano, alcanzar libertad (8) y contactar sentimientos (4).",example:"Reich: en un cuerpo inflexible solo habitan sentimientos rastreros."},3:{title:"Psiquis (sentimiento)",desc:"⚡ Descubro que existe algo más — estados de ánimo que no se tratan con duchas frías."},4:{title:"Percibo mis sentimientos",desc:"Me relaciono con mis sentimientos. Experimento dependencia de impulsos que surgen del cuerpo."},5:{title:"Influyo sobre mis sentimientos",desc:"Para no ser esclavo de estados de ánimo. Se necesita una nueva cualidad."},6:{title:"Espíritu (intelecto)",desc:"⚡ Descubro el poder del espíritu. Comienzo a comprenderme en un nuevo nivel."},7:{title:"Me comprendo",desc:"Solo cuando cuerpo es flexible (1) y soy dueño de sentimientos (5). Los tres centros cooperan."},8:{title:"Alcanzo la libertad",desc:"Domino sentimientos (5) y cuerpo (2). El Self aparece y da dirección.",example:"El cochero dirige los caballos, el carruaje llega a destino."},9:{title:"Ser humano integrado",desc:"Coniunctio alquímica. Más allá de lo masculino y femenino."}}},cocina:{name:"La cocina como cosmos",points:{1:{title:"La cocina está lista",desc:"Condiciones materiales preparadas. Cocina = Cuerpo."},2:{title:"Comienza el trabajo",desc:"Proceso mecánico. Manos en acción."},3:{title:"Los ingredientes",desc:"⚡ Lo que viene de AFUERA. Sin ingredientes no hay comida.",example:"Ingredientes = experiencias / alma"},4:{title:"Preparando ingredientes",desc:"Transformar lo crudo. Cortar, pelar, medir."},5:{title:"Cocinando",desc:"El fuego transforma. No se puede apurar."},6:{title:"El grupo que recibirá",desc:"⚡ La presencia de quienes recibirán da sentido a todo."},7:{title:"Sirviendo",desc:"Presentar lo creado."},8:{title:"Consumiendo",desc:"La meta se cumple. El alimento nutre."},9:{title:"Vida",desc:"El alimento se transforma en vida. Nuevo ciclo.",example:"Cocinero = voluntad/espíritu"}}},libro:{name:"Escribir un libro (Vollmar)",points:{1:{title:"Ordenador con programa",desc:"Condición material para componer."},2:{title:"Leer, acumular experiencia",desc:"Conocimiento práctico y experiencia."},3:{title:"La idea (la Musa)",desc:"⚡ Surgió en conversación con el editor."},4:{title:"Ordenar el material",desc:"Qué incluir/excluir. Establecer límites."},5:{title:"Planificar estructura",desc:"Tarea más difícil: índice, organización."},6:{title:"El editor",desc:"⚡ Longitud, alcance, contrato."},7:{title:"Se publica",desc:"Toda la energía al servicio de la meta."},8:{title:"Se lee el libro",desc:"Si el lector sigue leyendo, la meta se cumplió."},9:{title:"Ideas para otro libro",desc:"El lector aplica el eneagrama. Nuevo ciclo.",example:"Punto 9 de este libro = punto 1 de tu eneagrama."}}}};

let cT='infelicidad',aP=null,wS=-1;
const cx=250,cy=260,R=200,circ=2*Math.PI*R;
const pC={1:'var(--section1)',2:'var(--section1)',3:'var(--shock)',4:'var(--section2)',5:'var(--section2)',6:'var(--shock)',7:'var(--section3)',8:'var(--section3)',9:'var(--purple)'};
const sO={1:1,2:1,3:0,4:2,5:2,6:0,7:3,8:3,9:0};
const sN={1:'Sección 1',2:'Sección 2',3:'Sección 3',0:'Choque'};
const sC={1:'var(--section1)',2:'var(--section2)',3:'var(--section3)',0:'var(--shock)'};
const hS=[1,4,2,8,5,7],tS=[3,6,9];

function gP(n){const a=((n%9)*40-90)*Math.PI/180;return{x:cx+R*Math.cos(a),y:cy+R*Math.sin(a)}}
function gL(n){const a=((n%9)*40-90)*Math.PI/180;const lr=R+28;return{x:cx+lr*Math.cos(a),y:cy+lr*Math.sin(a)}}

document.addEventListener('DOMContentLoaded',()=>{
document.querySelectorAll('.nav-tab').forEach(t=>t.addEventListener('click',()=>{
document.querySelectorAll('.nav-tab').forEach(x=>x.classList.remove('active'));
document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
t.classList.add('active');document.getElementById('page-'+t.dataset.page).classList.add('active');
}));
bS();loadT('infelicidad');
});

function bS(){
const tG=document.getElementById('tG'),hG=document.getElementById('hG'),pG=document.getElementById('pG'),lG=document.getElementById('lG');
for(let i=0;i<3;i++){const p1=gP(tS[i]),p2=gP(tS[(i+1)%3]);const l=document.createElementNS('http://www.w3.org/2000/svg','line');l.setAttribute('x1',p1.x);l.setAttribute('y1',p1.y);l.setAttribute('x2',p2.x);l.setAttribute('y2',p2.y);l.setAttribute('class','enn-triangle-line');tG.appendChild(l);}
for(let i=0;i<hS.length;i++){const p1=gP(hS[i]),p2=gP(hS[(i+1)%hS.length]);const l=document.createElementNS('http://www.w3.org/2000/svg','line');l.setAttribute('x1',p1.x);l.setAttribute('y1',p1.y);l.setAttribute('x2',p2.x);l.setAttribute('y2',p2.y);l.setAttribute('class','enn-hex-line');l.dataset.f=hS[i];l.dataset.t=hS[(i+1)%hS.length];hG.appendChild(l);}
for(let n=1;n<=9;n++){const p=gP(n),lp=gL(n);const g=document.createElementNS('http://www.w3.org/2000/svg','g');g.setAttribute('class','enn-point');g.dataset.p=n;g.addEventListener('click',()=>sP(n));
const c=document.createElementNS('http://www.w3.org/2000/svg','circle');c.setAttribute('cx',p.x);c.setAttribute('cy',p.y);c.setAttribute('r',18);c.setAttribute('fill',pC[n]);c.setAttribute('opacity','.85');
const t=document.createElementNS('http://www.w3.org/2000/svg','text');t.setAttribute('x',p.x);t.setAttribute('y',p.y);t.textContent=n;
g.appendChild(c);g.appendChild(t);pG.appendChild(g);
const lb=document.createElementNS('http://www.w3.org/2000/svg','text');lb.setAttribute('x',lp.x);lb.setAttribute('y',lp.y+4);lb.setAttribute('class','enn-label');lb.id='l-'+n;lG.appendChild(lb);}}

function uPA(n){const a=document.getElementById('pArc');if(!n||n<1){a.style.strokeDashoffset=circ;return;}a.style.strokeDashoffset=circ*(1-(n%9)/9);}

function loadT(k){cT=k;aP=null;wS=-1;
document.querySelectorAll('.template-card').forEach(c=>c.classList.toggle('active',c.dataset.template===k));
const tm=T[k];for(let n=1;n<=9;n++){const lb=document.getElementById('l-'+n);const t=tm.points[n]?.title||'';lb.textContent=t.length>20?t.slice(0,18)+'…':t;}
document.getElementById('piN').textContent='◎';document.getElementById('piN').style.color='var(--accent)';
document.getElementById('piS').textContent='';document.getElementById('piT').textContent=tm.name;
document.getElementById('piD').textContent='Click en cualquier punto (1-9) o usa ▶';
document.getElementById('piE').style.display='none';document.getElementById('piO').style.display='none';
document.getElementById('cD').textContent='';document.getElementById('pI').classList.remove('shock');
document.querySelectorAll('.enn-point').forEach(g=>g.classList.remove('active'));
document.querySelectorAll('.enn-hex-line').forEach(l=>l.classList.remove('highlight'));
document.querySelectorAll('.enn-label').forEach(l=>l.classList.remove('active'));
document.querySelectorAll('.octave-note').forEach(n=>n.classList.remove('active'));
uPA(0);uSL();}

function sP(n){aP=n;wS=n-1;const tm=T[cT];const d=tm.points[n];if(!d)return;const s=sO[n];
document.getElementById('piN').textContent=n;document.getElementById('piN').style.color=pC[n];
const sl=document.getElementById('piS');sl.textContent=sN[s];sl.style.background=sC[s];sl.style.color=s===0?'#fff':'#000';sl.style.opacity='.8';
document.getElementById('piT').textContent=d.title;document.getElementById('piD').textContent=d.desc;
const e=document.getElementById('piE');if(d.example){e.textContent=d.example;e.style.display='block';}else e.style.display='none';
const o=document.getElementById('piO');if(d.octave){o.textContent='♪ '+d.octave;o.style.display='block';}else o.style.display='none';
document.getElementById('pI').classList.toggle('shock',n===3||n===6);
document.querySelectorAll('.enn-point').forEach(g=>g.classList.toggle('active',parseInt(g.dataset.p)===n));
document.querySelectorAll('.enn-label').forEach(l=>l.classList.toggle('active',parseInt(l.id.split('-')[1])===n));
document.querySelectorAll('.enn-hex-line').forEach(l=>{const f=parseInt(l.dataset.f),t=parseInt(l.dataset.t);l.classList.toggle('highlight',f===n||t===n);});
document.querySelectorAll('.octave-note').forEach(x=>x.classList.toggle('active',parseInt(x.dataset.n)===n));
uPA(n);
const ln=[];const hi=hS.indexOf(n);if(hi!==-1)ln.push('Hex: '+hS[(hi-1+6)%6]+'→['+n+']→'+hS[(hi+1)%6]);
const ti=tS.indexOf(n);if(ti!==-1)ln.push('Tri: '+tS[(ti-1+3)%3]+'→['+n+']→'+tS[(ti+1)%3]);
ln.push('Círculo: '+(n===1?9:n-1)+'→['+n+']→'+(n===9?1:n+1));
document.getElementById('cD').innerHTML=ln.join('<br>');uSL();}

function wN(){wS=(wS+1)%9;sP(wS+1);}
function wP(){wS=(wS-1+9)%9;sP(wS+1);}
function wR(){wS=-1;loadT(cT);}
function uSL(){document.getElementById('stepLabel').textContent=aP?'Punto '+aP+' / 9':'— / 9';}
function tH(){document.getElementById('hG').style.display=document.getElementById('shH').checked?'':'none';}
function tT(){document.getElementById('tG').style.display=document.getElementById('shT').checked?'':'none';}

